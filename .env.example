# GitHub
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=
GITHUB_FETCH_CONCURRENCY=25
FILE_PROCESSING_CONCURRENCY=8
FILE_PROCESSING_BATCH_SIZE=10
INGEST_SOURCE=github_api
GIT_CLONE_TIMEOUT_SECONDS=300
GITHUB_REQUEST_TIMEOUT_SECONDS=30
GITHUB_CONNECT_TIMEOUT_SECONDS=10
GITHUB_MAX_KEEPALIVE_CONNECTIONS=25
GITHUB_MAX_CONNECTIONS=50
GITHUB_RETRY_ATTEMPTS=3
INGEST_JOB_MAX_AGE_SECONDS=3600
INGEST_JOB_MAX_EVENTS=500
JOB_STORE_BACKEND=memory
# Required when JOB_STORE_BACKEND=redis.
REDIS_URL=redis://localhost:6379/0
SESSION_STORE_BACKEND=memory
SESSION_TTL_SECONDS=86400
# Required when SESSION_STORE_BACKEND=redis. Generate a strong random value and keep it secret.
SESSION_ENCRYPTION_KEY=
CACHE_BACKEND=redis
GITHUB_CACHE_TTL_SECONDS=600
REPORT_CACHE_TTL_SECONDS=86400
QUOTA_BACKEND=redis
MAX_REPOS_PER_USER=2
MAX_ELIGIBLE_FILES=500
MAX_CHUNKS_PER_REPO=3000
MAX_ACTIVE_INGESTS_PER_USER=1
MAX_GLOBAL_ACTIVE_INGESTS=2
MAX_INGESTS_PER_USER_PER_DAY=2
MAX_QUERIES_PER_USER_PER_DAY=30
MAX_HEALTH_CHECKS_PER_REPO_COMMIT=1

# GitHub OAuth App (required for "Continue with GitHub" login)
# Register at: https://github.com/settings/developers → New OAuth App
# Callback URL must be: {FRONTEND_URL}/auth/callback  (e.g. http://localhost:3000/auth/callback)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Embeddings
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
VERTEX_EMBEDDING_MAX_TEXT_CHARS=20000
VERTEX_EMBEDDING_RETRY_ATTEMPTS=3

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cortex_kb

# Neo4j AuraDB
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# LLMs
GROQ_API_KEY=
GEMINI_API_KEY=

# Embeddings
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_DIR=C:\tmp\cortex_fastembed_cache
# Set true after the model has been downloaded into EMBEDDING_CACHE_DIR.
EMBEDDING_LOCAL_FILES_ONLY=false
# Use cpu by default. For local GPU testing install fastembed-gpu, then set cuda.
EMBEDDING_DEVICE=cpu

# App
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
